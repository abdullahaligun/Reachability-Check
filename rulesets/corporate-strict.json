{
  "meta": {
    "id": "corporate-strict",
    "name": "Kurumsal — Katı Politika",
    "description": "Strict corporate network policy. All listed services must be reachable and performant. Intended for IT/network compliance audits.",
    "version": "1.0.0",
    "author": "netscope-community",
    "tags": ["corporate", "compliance", "it-audit"],
    "on_failure": "alert"
  },
  "rules": [
    {
      "id": "rule-github-access",
      "name": "GitHub Erişimi",
      "description": "Developer workflow requires GitHub to be reachable",
      "service": { "name": "GitHub", "host": "github.com", "url": "https://github.com", "favicon": "https://github.com/favicon.ico" },
      "severity": "critical",
      "conditions": {
        "must_reach": true,
        "max_ping_ms": 800
      },
      "fail_message": "GitHub erişilemiyor — geliştirici iş akışı sekteye uğrayabilir.",
      "pass_message": "GitHub erişilebilir."
    },
    {
      "id": "rule-slack-access",
      "name": "Slack Erişimi",
      "description": "Internal communication requires Slack",
      "service": { "name": "Slack", "host": "slack.com", "url": "https://slack.com", "favicon": "https://slack.com/favicon.ico" },
      "severity": "critical",
      "conditions": {
        "must_reach": true,
        "max_ping_ms": 600
      },
      "fail_message": "Slack erişilemiyor — iletişim kanalı yok.",
      "pass_message": "Slack erişilebilir."
    },
    {
      "id": "rule-zoom-latency",
      "name": "Zoom Gecikme Sınırı",
      "description": "Video calls require low latency",
      "service": { "name": "Zoom", "host": "zoom.us", "url": "https://zoom.us", "favicon": "https://zoom.us/favicon.ico" },
      "severity": "warning",
      "conditions": {
        "must_reach": true,
        "max_ping_ms": 200
      },
      "fail_message": "Zoom gecikmesi yüksek — video görüşmeleri etkilenebilir.",
      "pass_message": "Zoom gecikmesi kabul edilebilir aralıkta."
    },
    {
      "id": "rule-social-blocked",
      "name": "Sosyal Medya Engeli",
      "description": "Corporate policy: social media should NOT be accessible",
      "service": { "name": "Instagram", "host": "instagram.com", "url": "https://www.instagram.com", "favicon": "https://www.instagram.com/favicon.ico" },
      "severity": "warning",
      "conditions": {
        "must_reach": false
      },
      "fail_message": "Instagram ağ içinden erişilebilir — politikaya aykırı olabilir.",
      "pass_message": "Instagram ağ politikasına uygun olarak engellendi."
    },
    {
      "id": "rule-tiktok-blocked",
      "name": "TikTok Engeli",
      "description": "Corporate policy: TikTok must be blocked",
      "service": { "name": "TikTok", "host": "tiktok.com", "url": "https://www.tiktok.com", "favicon": "https://www.tiktok.com/favicon.ico" },
      "severity": "critical",
      "conditions": {
        "must_reach": false
      },
      "fail_message": "TikTok ağ içinden erişilebilir — güvenlik politikası ihlali.",
      "pass_message": "TikTok doğru şekilde engellendi."
    },
    {
      "id": "rule-cloudflare-dns",
      "name": "Cloudflare Erişimi",
      "description": "CDN and DNS infrastructure must be reachable",
      "service": { "name": "Cloudflare", "host": "cloudflare.com", "url": "https://www.cloudflare.com", "favicon": "https://www.cloudflare.com/favicon.ico" },
      "severity": "info",
      "conditions": {
        "must_reach": true,
        "max_ping_ms": 400
      },
      "fail_message": "Cloudflare erişilemiyor — CDN servisleri etkilenebilir.",
      "pass_message": "Cloudflare altyapısı erişilebilir."
    }
  ]
}
